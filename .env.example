# PAO Environment Variables Example
# Duplicate this file to .env and adjust as needed

# Database Configuration (PostgreSQL Default)
DB_URL=jdbc:postgresql://localhost:5432/dao_db?currentSchema=pao_db
DB_USERNAME=postgres
DB_PASSWORD=password
DB_SCHEMA=pao_db
DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect
DB_DRIVER=org.postgresql.Driver

# For SQLite usage instead:
# DB_URL=jdbc:sqlite:pao.db
# DB_DRIVER=org.sqlite.JDBC
# DB_DIALECT=org.hibernate.community.dialect.SQLiteDialect
# DB_SCHEMA=

# AI & External Services
# GEMINI_KEY (Can also be set in the UI under Settings)
GEMINI_KEY=REPLACE_ME
DEFAULT_MODEL=gemini-1.5-flash

OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:35b
PREFER_LOCAL_LLM=false

MCP_URL=http://localhost:3013

# LOG_LEVEL_SQL=DEBUG
